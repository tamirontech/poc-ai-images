# Image Generation: OpenAI DALL-E
# Get key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Image Generation: Hugging Face
# Get token from: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_...
HUGGINGFACE_MODEL=stable-diffusion-3

# Image Generation: Replicate
# Get API key from: https://replicate.com/signin
# Preferred:
REPLICATE_API_TOKEN=r8_...
# Backward compatible:
REPLICATE_API_KEY=r8_...
REPLICATE_MODEL=stable-diffusion-3

# Application Configuration
APP_ENV=development
LOG_LEVEL=INFO
OUTPUT_DIR=./outputs
LOGS_DIR=./logs

# DALL-E Configuration
DALLE_MODEL=dall-e-3
# Fallback default size only; aspect ratio generation uses:
# 1:1 -> 1024x1024, 9:16 -> 1024x1792, 16:9 -> 1792x1024
IMAGE_SIZE=1024x1024

# Compliance Configuration
PROHIBITED_WORDS=["free","guaranteed","cure","miracle","100% effective"]
